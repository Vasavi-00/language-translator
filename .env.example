# Django
SECRET_KEY=change-this-to-a-random-secret-key
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# CORS (comma separated list of allowed origins, used in production)
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Translation engine: "google" (via deep-translator, free, no key needed)
# or "libre" (LibreTranslate, free/self-hostable)
TRANSLATION_ENGINE=google

# Only needed if TRANSLATION_ENGINE=libre and you use a hosted instance with a key
LIBRETRANSLATE_URL=https://libretranslate.com/translate
LIBRETRANSLATE_API_KEY=
